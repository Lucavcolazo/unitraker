# Copiar a .env y rellenar con los valores de tu proyecto en Supabase.
# No subir .env al repositorio (ya está en .gitignore).

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# URL pública de la app (obligatoria en producción). Evita que OAuth redirija a localhost.
# En Vercel: https://unitraker.vercel.app (o tu dominio).
# En local: no hace falta; se usa window.location.origin.
VITE_APP_URL=
